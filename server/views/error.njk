{% extends "base.njk" %}

{% block titulo %}Error — KnowMe{% endblock %}

{% block contenido %}

<div class="min-h-screen bg-[#0a0a0f] text-slate-300 flex items-center justify-center px-4">
  <div class="w-full max-w-md flex flex-col items-center gap-6 text-center">

    <div class="flex flex-col gap-2">
      <p class="text-[10px] font-mono text-red-400 uppercase tracking-widest">// error</p>
      <h1 class="text-2xl font-mono font-bold text-slate-100 tracking-tight">Algo ha ido mal</h1>
    </div>

    <div class="w-full bg-[#0f0f18] border border-red-500/20 rounded-2xl overflow-hidden">
      <div class="h-px bg-gradient-to-r from-transparent via-red-500/40 to-transparent"></div>
      <div class="p-6 flex items-start gap-3">
        <span class="text-red-400 font-mono text-sm mt-0.5 shrink-0">✕</span>
        <p class="text-sm font-mono text-red-400/80 text-left leading-relaxed">
          {% if error %}{{ error }}{% else %}Error inesperado en la aplicación.{% endif %}
        </p>
      </div>
    </div>

    <a href="javascript:history.back()"
       class="text-xs font-mono text-slate-600 hover:text-emerald-400 transition-colors">
      ← volver atrás
    </a>

  </div>
</div>

{% endblock %}
