{% extends "base.njk" %}

{% block titulo %}KnowMe — Portfolios de Desarrolladores{% endblock %}

{% block contenido %}

<div id="home-wrapper" class="bg-[#0a0a0f] text-slate-300 overflow-x-hidden">

  <!-- ═══════════════════════════════════════════════════
       HERO
  ════════════════════════════════════════════════════ -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">

    <!-- Grid background -->
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute inset-0" style="background-image: linear-gradient(rgba(99,255,180,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(99,255,180,0.04) 1px, transparent 1px); background-size: 48px 48px; mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%)"></div>
      <div class="absolute top-1/4 left-1/4 w-96 h-96 rounded-full" style="background: radial-gradient(circle, rgba(124,111,255,0.08) 0%, transparent 70%)"></div>
      <div class="absolute bottom-1/4 right-1/4 w-64 h-64 rounded-full" style="background: radial-gradient(circle, rgba(99,255,180,0.06) 0%, transparent 70%)"></div>
    </div>

    <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
      <p id="hero-eyebrow" class="font-mono text-emerald-400 text-sm tracking-widest uppercase mb-6 opacity-0">
        // plataforma para desarrolladores
      </p>
      <h1 id="hero-title" class="text-5xl md:text-7xl font-bold text-white leading-tight tracking-tight mb-6 opacity-0" style="font-family: 'Syne', sans-serif">
        Tu código.<br>
        <span style="background: linear-gradient(135deg, #63ffb4, #7c6fff); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Tu historia.</span>
      </h1>
      <p id="hero-desc" class="text-slate-400 text-lg md:text-xl leading-relaxed max-w-2xl mx-auto mb-10 opacity-0">
        KnowMe es el espacio donde los programadores muestran lo que realmente saben hacer. Sin filtros, sin adornos — solo proyectos reales y tecnologías que dominan.
      </p>
      <div id="hero-btns" class="flex items-center justify-center gap-4 flex-wrap opacity-0">
        <a href="/porfolios" class="px-6 py-3 bg-emerald-500 hover:bg-emerald-400 text-[#0a0a0f] font-mono font-bold text-sm rounded-lg transition-all hover:-translate-y-0.5">
          Explorar portfolios
        </a>
        <a href="#sobre-knowme" class="px-6 py-3 bg-transparent border border-slate-700 hover:border-emerald-500/50 text-slate-300 hover:text-emerald-400 font-mono text-sm rounded-lg transition-all">
          Saber más
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div id="scroll-indicator" class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-0">
      <span class="text-xs font-mono text-slate-600">scroll</span>
      <div class="w-px h-12 bg-gradient-to-b from-slate-600 to-transparent"></div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════
       QUÉ ES KNOWME
  ════════════════════════════════════════════════════ -->
  <section id="sobre-knowme" class="py-32 max-w-[1200px] mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div class="reveal">
        <p class="text-xs font-mono text-emerald-400 uppercase tracking-widest mb-4">// qué es knowme</p>
        <h2 class="text-4xl font-bold text-white mb-6 leading-tight" style="font-family: 'Syne', sans-serif">
          LinkedIn no era suficiente.<br>Hicimos algo mejor.
        </h2>
        <p class="text-slate-400 leading-relaxed mb-4">
          KnowMe nació de una necesidad real: los portfolios técnicos merecen un espacio propio. Un lugar donde lo que importa es el código, los proyectos y las tecnologías que dominas — no cuántas empresas te han dado like.
        </p>
        <p class="text-slate-400 leading-relaxed">
          La plataforma funciona por invitación, lo que garantiza una comunidad de calidad. Cada desarrollador registrado puede invitar a otros, manteniendo el ecosistema cerrado y relevante.
        </p>
      </div>

      <!-- Terminal -->
      <div class="reveal">
        <div class="bg-[#0d0d14] border border-slate-800 rounded-xl overflow-hidden shadow-2xl shadow-black/50">
          <div class="flex items-center gap-2 px-4 py-3 bg-[rgba(255,255,255,0.03)] border-b border-slate-800">
            <div class="w-3 h-3 rounded-full bg-[#ff5f56]"></div>
            <div class="w-3 h-3 rounded-full bg-[#ffbd2e]"></div>
            <div class="w-3 h-3 rounded-full bg-[#27c93f]"></div>
            <span class="font-mono text-xs text-slate-500 mx-auto">knowme ~ terminal</span>
          </div>
          <div class="p-6 font-mono text-sm space-y-2">
            <p><span class="text-slate-600">$</span> <span class="text-white">knowme register</span> <span class="text-violet-400">--invite="A3F9"</span></p>
            <p class="text-slate-500">→ Validando invitación...</p>
            <p class="text-emerald-400">✓ Bienvenido a KnowMe</p>
            <p class="mt-2"><span class="text-slate-600">$</span> <span class="text-white">knowme portfolio</span> <span class="text-violet-400">--new</span></p>
            <p class="text-slate-500">→ Creando portfolio...</p>
            <p class="text-slate-500">→ Subiendo media a Cloudinary...</p>
            <p class="text-emerald-400">✓ Portfolio publicado</p>
            <p class="mt-2"><span class="text-slate-600">$</span> <span class="text-white">knowme search</span> <span class="text-violet-400">--skill="React"</span></p>
            <p class="text-emerald-400">✓ 142 desarrolladores encontrados</p>
            <p class="text-emerald-400 animate-pulse">█</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════
       CÓMO FUNCIONA
  ════════════════════════════════════════════════════ -->
  <section class="py-32 border-t border-slate-800/50">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="text-center mb-16 reveal">
        <p class="text-xs font-mono text-emerald-400 uppercase tracking-widest mb-4">// cómo funciona</p>
        <h2 class="text-4xl font-bold text-white" style="font-family: 'Syne', sans-serif">Simple. Visual. Directo.</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="reveal feature-card bg-[#0f0f18] border border-slate-800 rounded-xl p-8 hover:border-emerald-500/30 transition-all duration-300 hover:-translate-y-1">
          <div class="text-5xl font-bold font-mono mb-6" style="color: rgba(99,255,180,0.12)">01</div>
          <h3 class="text-lg font-bold text-white mb-3">Invitación</h3>
          <p class="text-slate-500 text-sm leading-relaxed">La plataforma es solo por invitación. Cada usuario genera hasta 10 keys para invitar a quien considere. La calidad antes que la cantidad.</p>
        </div>
        <div class="reveal feature-card bg-[#0f0f18] border border-slate-800 rounded-xl p-8 hover:border-emerald-500/30 transition-all duration-300 hover:-translate-y-1" style="transition-delay: 0.1s">
          <div class="text-5xl font-bold font-mono mb-6" style="color: rgba(99,255,180,0.12)">02</div>
          <h3 class="text-lg font-bold text-white mb-3">Sube tus proyectos</h3>
          <p class="text-slate-500 text-sm leading-relaxed">Añade imágenes, vídeos, snippets de código, tecnologías usadas y enlaces a GitHub o demo en vivo. Todo en un solo lugar.</p>
        </div>
        <div class="reveal feature-card bg-[#0f0f18] border border-slate-800 rounded-xl p-8 hover:border-emerald-500/30 transition-all duration-300 hover:-translate-y-1" style="transition-delay: 0.2s">
          <div class="text-5xl font-bold font-mono mb-6" style="color: rgba(99,255,180,0.12)">03</div>
          <h3 class="text-lg font-bold text-white mb-3">Conéctate</h3>
          <p class="text-slate-500 text-sm leading-relaxed">Cualquiera puede explorar y contactar con desarrolladores sin estar registrado. Tu trabajo habla por ti.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- STACK TECNOLÓGICO -->
  <section class="py-32 border-t border-slate-800/50">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="text-center mb-16 reveal">
        <p class="text-xs font-mono text-emerald-400 uppercase tracking-widest mb-4">// construido con</p>
        <h2 class="text-4xl font-bold text-white" style="font-family: 'Syne', sans-serif">El stack detrás de KnowMe</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {% set stack = [
          { name: "Node.js", category: "Backend", color: "emerald" },
          { name: "Express", category: "Backend", color: "emerald" },
          { name: "MongoDB", category: "Base de datos", color: "emerald" },
          { name: "Mongoose", category: "ODM", color: "emerald" },
          { name: "Nunjucks", category: "Templating", color: "violet" },
          { name: "Tailwind CSS", category: "Estilos", color: "violet" },
          { name: "Vite", category: "Bundler", color: "violet" },
          { name: "GSAP", category: "Animaciones", color: "violet" },
          { name: "Cloudinary", category: "Media", color: "amber" },
          { name: "JWT", category: "Auth", color: "amber" },
          { name: "bcrypt", category: "Seguridad", color: "amber" },
          { name: "Helmet", category: "Seguridad", color: "amber" }
        ] %}
        {% for item in stack %}
        <div class="reveal stack-card bg-[#0f0f18] border border-slate-800 rounded-lg p-4 hover:border-slate-600 transition-all group">
          <p class="text-sm font-bold text-white font-mono group-hover:text-emerald-400 transition-colors">{{ item.name }}</p>
          <p class="text-xs text-slate-600 font-mono mt-1">{{ item.category }}</p>
        </div>
        {% endfor %}
      </div>
      <div class="mt-12 reveal">
        <p class="text-xs font-mono text-emerald-400 uppercase tracking-widest mb-4">// lenguajes</p>
        <div class="flex flex-wrap gap-3">
          {% set langs = ["JavaScript", "HTML", "CSS", "Nunjucks"] %}
          {% for lang in langs %}
          <span class="px-4 py-2 bg-[#0f0f18] border border-slate-800 rounded-full text-sm font-mono text-slate-300">{{ lang }}</span>
          {% endfor %}
        </div>
      </div>
    </div>
  </section>

  <!-- CREADORES -->
  <section class="py-32 border-t border-slate-800/50">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="text-center mb-16 reveal">
        <p class="text-xs font-mono text-emerald-400 uppercase tracking-widest mb-4">// quiénes somos</p>
        <h2 class="text-4xl font-bold text-white" style="font-family: 'Syne', sans-serif">Los que lo hicieron posible</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

        <!-- Jordi -->
        <a href="https://github.com/JordiVU" target="_blank"
          class="reveal creator-card group bg-[#0f0f18] border border-slate-800 rounded-2xl p-8 hover:border-emerald-500/40 transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl hover:shadow-black/50 block">
          <div class="flex items-start gap-5 mb-6">
            <div class="w-16 h-16 rounded-xl overflow-hidden border-2 border-slate-700 group-hover:border-emerald-500/50 transition-all shrink-0">
              <img src="https://avatars.githubusercontent.com/u/148686789?v=4" alt="Jordi" class="w-full h-full object-cover"/>
            </div>
            <div>
              <h3 class="text-xl font-bold text-white group-hover:text-emerald-400 transition-colors" style="font-family: 'Syne', sans-serif">Jordi Vázquez Uribe</h3>
              <p class="text-xs font-mono text-slate-500 mt-1">@JordiVU</p>
              <div class="flex items-center gap-1 mt-2">
                <span class="w-2 h-2 rounded-full bg-emerald-400"></span>
                <span class="text-xs font-mono text-emerald-400">Disponible</span>
              </div>
            </div>
          </div>
          <p class="text-sm text-slate-400 leading-relaxed mb-6">
            Estudiante de DAM/DAW con experiencia en prácticas en NTTData, técnico en Tecnofix y actualmente desarrollador en Conwork. Apasionado por el desarrollo y siempre buscando aprender más.
          </p>
          <div class="flex flex-wrap gap-2 mb-6">
            {% for skill in ["JavaScript", "Java", "C#", "HTML", "CSS", "Python", "MySQL", "MongoDB", "Node.js", "MySQL", "MongoDB", "Git"] %}
            <span class="px-2.5 py-1 bg-slate-800 border border-slate-700 rounded-full text-[11px] font-mono text-slate-400">{{ skill }}</span>
            {% endfor %}
          </div>
          <div class="flex items-center gap-2 text-xs font-mono text-slate-600 group-hover:text-emerald-400 transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
            </svg>
            Ver en GitHub →
          </div>
        </a>

        <!-- Jorge -->
        <a href="https://github.com/JorgeDR06" target="_blank"
          class="reveal creator-card group bg-[#0f0f18] border border-slate-800 rounded-2xl p-8 hover:border-violet-500/40 transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl hover:shadow-black/50 block">
          <div class="flex items-start gap-5 mb-6">
            <div class="w-16 h-16 rounded-xl overflow-hidden border-2 border-slate-700 group-hover:border-violet-500/50 transition-all shrink-0 bg-gradient-to-br from-violet-500 to-emerald-500 flex items-center justify-center">
              <span class="text-2xl font-bold text-white">J</span>
            </div>
            <div>
              <h3 class="text-xl font-bold text-white group-hover:text-violet-400 transition-colors" style="font-family: 'Syne', sans-serif">Jorge Díaz Ramírez</h3>
              <p class="text-xs font-mono text-slate-500 mt-1">@JorgeDR06</p>
              <div class="flex items-center gap-1 mt-2">
                <span class="w-2 h-2 rounded-full bg-violet-400"></span>
                <span class="text-xs font-mono text-violet-400">Disponible</span>
              </div>
            </div>
          </div>
          <p class="text-sm text-slate-400 leading-relaxed mb-6">
            Estudiante de DAM/DAW especializado en desarrollo web full stack. Apasionado por construir aplicaciones robustas y escalables, con especial interés en la seguridad y la arquitectura de software.
          </p>
          <div class="flex flex-wrap gap-2 mb-6">
            {% for skill in ["JavaScript", "Node.js", "Express", "MongoDB", "React", "HTML", "CSS", "Git"] %}
            <span class="px-2.5 py-1 bg-slate-800 border border-slate-700 rounded-full text-[11px] font-mono text-slate-400">{{ skill }}</span>
            {% endfor %}
          </div>
          <div class="flex items-center gap-2 text-xs font-mono text-slate-600 group-hover:text-violet-400 transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
            </svg>
            Ver en GitHub →
          </div>
        </a>

      </div>
    </div>
  </section>

  <section class="py-32 border-t border-slate-800/50">
    <div class="max-w-[800px] mx-auto px-6 text-center reveal">
      <p class="text-xs font-mono text-emerald-400 uppercase tracking-widest mb-6">// únete</p>
      <h2 class="text-5xl font-bold text-white mb-6 leading-tight" style="font-family: 'Syne', sans-serif">
        ¿Tienes una<br>
        <span style="background: linear-gradient(135deg, #63ffb4, #7c6fff); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">invitación?</span>
      </h2>
      <p class="text-slate-400 leading-relaxed mb-10 max-w-lg mx-auto">
        KnowMe es una comunidad cerrada. Si alguien confió en ti y te dio una key, es hora de mostrar lo que sabes hacer.
      </p>
      <div class="flex items-center justify-center gap-4 flex-wrap">
        <a href="/register" class="px-8 py-3.5 bg-emerald-500 hover:bg-emerald-400 text-[#0a0a0f] font-mono font-bold text-sm rounded-lg transition-all hover:-translate-y-0.5">
          Crear cuenta
        </a>
        <a href="/porfolios" class="px-8 py-3.5 border border-slate-700 hover:border-slate-500 text-slate-300 font-mono text-sm rounded-lg transition-all">
          Explorar sin cuenta
        </a>
      </div>
    </div>
  </section>

</div>

<script type="module">
  import { gsap } from 'http://localhost:5173/node_modules/gsap/index.js'

  // ── Hero animations ────────────────────────────────────────────────────
  const tl = gsap.timeline({ defaults: { ease: 'power3.out' } })

  tl.to('#hero-eyebrow', { opacity: 1, y: 0, duration: 0.8, delay: 0.2 })
    .to('#hero-title',   { opacity: 1, y: 0, duration: 0.8 }, '-=0.4')
    .to('#hero-desc',    { opacity: 1, y: 0, duration: 0.8 }, '-=0.4')
    .to('#hero-btns',    { opacity: 1, y: 0, duration: 0.8 }, '-=0.4')
    .to('#scroll-indicator', { opacity: 1, duration: 0.8 }, '-=0.2')

  // Set initial state
  gsap.set(['#hero-eyebrow', '#hero-title', '#hero-desc', '#hero-btns'], { y: 30 })

  // ── Scroll reveal ──────────────────────────────────────────────────────
  const reveals = document.querySelectorAll('.reveal')

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        gsap.to(entry.target, {
          opacity: 1,
          y: 0,
          duration: 0.8,
          ease: 'power3.out'
        })
        observer.unobserve(entry.target)
      }
    })
  }, { threshold: 0.15 })

  reveals.forEach(el => {
    gsap.set(el, { opacity: 0, y: 40 })
    observer.observe(el)
  })
</script>

{% endblock %}
