{% extends "base.njk" %}

{% block titulo %}Login — KnowMe{% endblock %}

{% block contenido %}

<div class="min-h-screen bg-[#0a0a0f] text-slate-300 flex justify-center px-4 py-16">
  <div class="w-full max-w-md flex flex-col gap-6">

    {# ── HEADER ─────────────────────────────────────────────────── #}
    <div class="text-center flex flex-col gap-1">
      <p class="text-xs font-mono text-emerald-400 uppercase tracking-widest">// acceso</p>
      <h1 class="text-2xl font-mono font-bold text-slate-100 tracking-tight">Bienvenido de nuevo</h1>
      <p class="text-sm text-slate-600 font-mono mt-1">Identifícate para continuar.</p>
    </div>

    {# ── FORM CARD ───────────────────────────────────────────────── #}
    <div class="bg-[#0f0f18] border border-slate-800 rounded-2xl overflow-hidden">

      <div class="h-px bg-gradient-to-r from-transparent via-emerald-500/40 to-transparent"></div>

      <form action="/users/login" method="post" class="p-8 flex flex-col gap-5">

        {# Error global #}
        {% if error %}
        <div class="flex items-start gap-2.5 px-4 py-3 bg-red-500/5 border border-red-500/20 rounded-lg">
          <span class="text-red-400 font-mono text-xs mt-0.5">✕</span>
          <p class="text-xs font-mono text-red-400">{{ error }}</p>
        </div>
        {% endif %}

        {# Email #}
        <div class="flex flex-col gap-1.5">
          <label for="email" class="text-xs font-mono text-emerald-400 uppercase tracking-widest">// correo electrónico</label>
          <input
            type="email"
            id="email"
            name="email"
            value="{{ formData.email if formData }}"
            placeholder="ejemplo@dominio.com"
            autocomplete="email"
            required
            class="w-full bg-[#0a0a0f] border border-slate-800 rounded-lg px-4 py-2.5 text-sm text-slate-200 placeholder-slate-700 font-mono focus:outline-none focus:border-emerald-500/50 focus:ring-1 focus:ring-emerald-500/20 transition-all {% if errors.email %}border-red-500/40{% endif %}"
          />
          {% if errors.email %}
            <p class="text-[10px] font-mono text-red-400/80">{{ errors.email }}</p>
          {% endif %}
        </div>

        {# Contraseña #}
        <div class="flex flex-col gap-1.5">
          <div class="flex items-center justify-between">
            <label for="password" class="text-xs font-mono text-emerald-400 uppercase tracking-widest">// contraseña</label>
          </div>
          <div class="relative">
            <input
              type="password"
              id="password"
              name="password"
              placeholder="Tu contraseña..."
              autocomplete="current-password"
              required
              class="w-full bg-[#0a0a0f] border border-slate-800 rounded-lg px-4 py-2.5 pr-11 text-sm text-slate-200 placeholder-slate-700 font-mono focus:outline-none focus:border-emerald-500/50 focus:ring-1 focus:ring-emerald-500/20 transition-all {% if errors.password %}border-red-500/40{% endif %}"
            />
            <button type="button" id="toggle-password"
              class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-600 hover:text-slate-400 transition-colors"
              aria-label="Mostrar contraseña">
              <svg id="eye-icon" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
              </svg>
            </button>
          </div>
          {% if errors.password %}
            <p class="text-[10px] font-mono text-red-400/80">{{ errors.password }}</p>
          {% endif %}
        </div>

        {# Submit #}
        <button
          type="submit"
          class="mt-2 w-full bg-emerald-500/10 border border-emerald-500/30 hover:bg-emerald-500/20 hover:border-emerald-500/50 text-emerald-400 font-mono text-sm rounded-lg py-2.5 transition-all duration-200 active:scale-[0.98]">
          Entrar →
        </button>

      </form>
    </div>

    {# ── FOOTER LINK ─────────────────────────────────────────────── #}
    <p class="text-center text-xs font-mono text-slate-700">
      ¿No tienes cuenta?
      <a href="/register" class="text-slate-500 hover:text-emerald-400 transition-colors ml-1">Regístrate →</a>
    </p>

  </div>
</div>

<script>
  const btn = document.getElementById('toggle-password');
  const input = document.getElementById('password');
  const icon = document.getElementById('eye-icon');
  const eyeOpen = `<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>`;
  const eyeClosed = `<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/>`;
  btn.addEventListener('click', () => {
    const show = input.type === 'password';
    input.type = show ? 'text' : 'password';
    icon.innerHTML = show ? eyeClosed : eyeOpen;
  });
</script>

{% endblock %}
