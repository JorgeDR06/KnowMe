<nav class="sticky top-0 z-50 bg-[#0a0a0f] border-b border-white/[0.06] font-mono">
  <div class="sticky max-w mx-auto px-6 h-14 flex items-center justify-between">

    <a href="/" class="flex items-center text-[15px] font-medium text-slate-200 hover:text-slate-50 tracking-tight transition-colors">
      <span class="text-emerald-500 text-base">&lt;</span>
      KnowMe
      <span class="text-emerald-500 text-base">/&gt;</span>
    </a>

    <button id="navToggle" aria-label="Abrir menú"
      class="hidden max-sm:flex flex-col gap-[5px] p-2">
      <span class="block w-5 h-px bg-slate-500 rounded-sm transition-all duration-200"></span>
      <span class="block w-5 h-px bg-slate-500 rounded-sm transition-all duration-200"></span>
      <span class="block w-5 h-px bg-slate-500 rounded-sm transition-all duration-200"></span>
    </button>

    <ul id="navLinks" class="flex items-center gap-1">

      <li>
        <a href="/"
          class="inline-block text-[11px] uppercase tracking-widest px-3 py-1.5 rounded-md border transition-all duration-150
                 {% if active == 'home' %}
                   text-emerald-400 border-emerald-500/25 bg-emerald-500/[0.06]
                 {% else %}
                   text-slate-500 border-transparent hover:text-slate-300 hover:border-white/[0.08] hover:bg-white/[0.04]
                 {% endif %}">
          Home
        </a>
      </li>

      <li>
        <a href="/porfolios"
          class="inline-block text-[11px] uppercase tracking-widest px-3 py-1.5 rounded-md border transition-all duration-150
                 {% if active == 'porfolios' %}
                   text-emerald-400 border-emerald-500/25 bg-emerald-500/[0.06]
                 {% else %}
                   text-slate-500 border-transparent hover:text-slate-300 hover:border-white/[0.08] hover:bg-white/[0.04]
                 {% endif %}">
          Porfolios
        </a>
      </li>

      {% if currentUser %}

        {% if currentUser.role === 'admin' %}
        <li>
          <a href="/usuarios"
            class="inline-block text-[11px] uppercase tracking-widest px-3 py-1.5 rounded-md border transition-all duration-150
                   {% if active == 'admin' %}
                     text-amber-400 border-amber-500/25 bg-amber-500/[0.06]
                   {% else %}
                     text-slate-500 border-transparent hover:text-amber-400 hover:border-amber-500/20 hover:bg-amber-500/[0.04]
                   {% endif %}">
            Usuarios
          </a>
        </li>
        {% endif %}

        {# Campana de notificaciones #}
        <li>
          <a href="/notificaciones"
            class="relative flex items-center justify-center w-8 h-8 rounded-md border border-transparent hover:border-white/[0.08] hover:bg-white/[0.04] transition-all
                   {% if active == 'notificaciones' %}
                     text-emerald-400 border-emerald-500/25 bg-emerald-500/[0.06]
                   {% else %}
                     text-slate-500 hover:text-slate-300
                   {% endif %}">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6 6 0 00-4-5.659V4a2 2 0 10-4 0v1.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
            </svg>
            {% if unreadCount and unreadCount > 0 %}
              <span class="absolute -top-1 -right-1 w-4 h-4 bg-emerald-500 rounded-full text-[9px] font-bold text-black flex items-center justify-center">
                {{ unreadCount if unreadCount < 10 else '9+' }}
              </span>
            {% endif %}
          </a>
        </li>

        <li>
          <a href="/perfil"
            class="inline-block text-[11px] uppercase tracking-widest px-3 py-1.5 rounded-md border transition-all duration-150
                   {% if active == 'perfil' %}
                     text-emerald-400 border-emerald-500/25 bg-emerald-500/[0.06]
                   {% else %}
                     text-slate-500 border-transparent hover:text-slate-300 hover:border-white/[0.08] hover:bg-white/[0.04]
                   {% endif %}">
            Perfil
          </a>
        </li>

        <li>
          <a href="/logout"
            class="inline-block text-[12px] uppercase tracking-widest ml-3 px-3 py-1.5 transition-all duration-150 hover:text-emerald-400 bg-transparent text-slate-500">
            Logout
          </a>
        </li>

      {% else %}

        <li>
          <a href="/login"
            class="inline-block text-[12px] uppercase tracking-widest ml-3 px-3 py-1.5 transition-all duration-150 hover:text-emerald-400 bg-transparent text-slate-500">
            Login
          </a>
        </li>

      {% endif %}

    </ul>
  </div>
</nav>
