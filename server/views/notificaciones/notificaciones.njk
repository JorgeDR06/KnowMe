{% extends "base.njk" %}

{% block titulo %}Notificaciones · KnowMe{% endblock %}

{% block contenido %}
<div class="min-h-screen bg-[#0a0a0f] text-slate-300">
  <div class="max-w-[700px] mx-auto px-6 py-10 flex flex-col gap-8">

    {# HEADER #}
    <div class="flex items-center justify-between">
      <div class="flex flex-col gap-1">
        <span class="text-[10px] font-mono text-emerald-400 uppercase tracking-widest">// bandeja de entrada</span>
        <h1 class="text-xl font-mono font-bold text-slate-100 tracking-tight">Notificaciones</h1>
      </div>
      {% if unreadCount and unreadCount > 0 %}
        <span class="text-[10px] font-mono text-slate-600">{{ unreadCount }} sin leer</span>
      {% endif %}
    </div>

    {# LISTA #}
    <div class="bg-[#0f0f18] border border-slate-800 rounded-2xl overflow-hidden">
      <div class="h-px bg-gradient-to-r from-transparent via-emerald-500/30 to-transparent"></div>

      {% if notifications and notifications | length > 0 %}
        <div class="divide-y divide-slate-800/50">
          {% for n in notifications %}
          <div class="px-6 py-4 flex items-start gap-4 cursor-pointer hover:bg-white/[0.02] transition-colors {{ 'bg-emerald-500/[0.03]' if not n.read }}"
               onclick="openModal('{{ n._id }}', `{{ n.message }}`, '{{ n.fechaFormateada }}', {{ 'false' if not n.read else 'true' }})">

            <span class="mt-2 w-1.5 h-1.5 rounded-full shrink-0 {{ 'bg-emerald-500' if not n.read else 'bg-slate-700' }}"></span>

            <div class="flex-1 min-w-0 flex flex-col gap-1">
              <p class="text-sm font-mono text-slate-300 line-clamp-2 leading-relaxed">{{ n.message }}</p>
              <span class="text-[10px] font-mono text-slate-600">{{ n.fechaFormateada }}</span>
            </div>

            {% if not n.read %}
              <span class="px-2 py-0.5 bg-emerald-500/10 border border-emerald-500/20 rounded text-emerald-400 font-mono text-[9px] uppercase tracking-widest shrink-0">nueva</span>
            {% endif %}

          </div>
          {% endfor %}
        </div>

      {% else %}
        <div class="py-16 flex flex-col items-center justify-center gap-2">
          <svg class="w-8 h-8 text-slate-800" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6 6 0 00-4-5.659V4a2 2 0 10-4 0v1.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
          </svg>
          <span class="font-mono text-sm text-slate-700 italic">// sin notificaciones</span>
        </div>
      {% endif %}

      <div class="px-6 py-3 border-t border-slate-800/50 flex items-center justify-end">
        <span class="text-[10px] font-mono text-slate-700">{{ notifications | length }} notificaciones en total</span>
      </div>
    </div>

  </div>
</div>

{# ── MODAL ──────────────────────────────────────────────────────── #}
<div id="modal" class="hidden fixed inset-0 z-[100] flex items-center justify-center px-4">
  <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" id="modalBackdrop"></div>
  <div class="relative w-full max-w-md bg-[#0f0f18] border border-slate-800 rounded-2xl overflow-hidden shadow-2xl">
    <div class="h-px bg-gradient-to-r from-transparent via-emerald-500/40 to-transparent"></div>
    <div class="p-6 flex flex-col gap-4">
      <div class="flex items-start justify-between gap-4">
        <div class="flex flex-col gap-1">
          <span class="text-[10px] font-mono text-emerald-400 uppercase tracking-widest">// notificación</span>
          <span id="modalDate" class="text-[10px] font-mono text-slate-600"></span>
        </div>
        <button id="modalClose" class="text-slate-600 hover:text-slate-300 transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <p id="modalMessage" class="text-sm font-mono text-slate-300 leading-relaxed"></p>
    </div>
  </div>
</div>

<script>
  const modal = document.getElementById('modal')
  const modalBackdrop = document.getElementById('modalBackdrop')
  const modalClose = document.getElementById('modalClose')
  const modalMessage = document.getElementById('modalMessage')
  const modalDate = document.getElementById('modalDate')

  async function openModal(id, message, date, isRead) {
    modalMessage.textContent = message
    modalDate.textContent = new Date(date).toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' })
    modal.classList.remove('hidden')

    if (!isRead) {
      await fetch(`/api/notificaciones/${id}/leer`, { method: 'PUT' })
      // Actualizar badge del menú
      const badge = document.querySelector('nav a[href="/notificaciones"] span')
      if (badge) {
        const current = parseInt(badge.textContent) || 1
        if (current <= 1) badge.remove()
        else badge.textContent = current - 1
      }
      // Quitar estilo de no leída en la fila
      event.currentTarget.classList.remove('bg-emerald-500/[0.03]')
      const dot = event.currentTarget.querySelector('span:first-child')
      if (dot) dot.className = 'mt-2 w-1.5 h-1.5 rounded-full shrink-0 bg-slate-700'
      const badge2 = event.currentTarget.querySelector('span:last-child')
      if (badge2 && badge2.textContent.trim() === 'nueva') badge2.remove()
    }
  }

  modalClose.addEventListener('click', () => modal.classList.add('hidden'))
  modalBackdrop.addEventListener('click', () => modal.classList.add('hidden'))
</script>

{% endblock %}
