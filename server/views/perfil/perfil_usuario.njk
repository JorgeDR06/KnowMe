{% extends "base.njk" %}

{% block titulo %}{{ user.name }} — KnowMe{% endblock %}

{% block contenido %}

<div class="min-h-screen bg-[#0a0a0f] text-slate-300">
  <form method="POST" action="/api/usuarios/{{ user._id }}/perfil">
  <input type="hidden" name="_method" value="PUT">
  <div class="max-w-[1100px] mx-auto px-6 py-10 flex flex-col gap-10">

    {% if error %}
    <div class="flex items-start gap-2.5 px-4 py-3 bg-red-500/5 border border-red-500/20 rounded-lg">
      <span class="text-red-400 font-mono text-xs mt-0.5">✕</span>
      <p class="text-xs font-mono text-red-400">{{ error }}</p>
    </div>
    {% endif %}

    {# HEADER CARD #}
    <div class="bg-[#0f0f18] border border-slate-800 rounded-2xl overflow-hidden">
      <div class="h-px bg-gradient-to-r from-transparent via-emerald-500/40 to-transparent"></div>

      <div class="p-8 flex flex-col sm:flex-row gap-8 items-start">

        {# Avatar #}
        <div class="flex flex-col gap-3 shrink-0 items-center">
          <div class="relative group cursor-pointer" onclick="document.getElementById('avatar-file').click()">
            <img id="avatar-preview"
                 src="{{ user.avatar or 'https://ui-avatars.com/api/?name=' + user.name + '&background=10b981&color=0a0a0f&size=96' }}"
                 alt="Avatar de {{ user.name }}"
                 class="w-24 h-24 rounded-xl object-cover border border-slate-700 ring-2 ring-emerald-500/20"/>
            <div class="absolute inset-0 rounded-xl bg-black/50 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13.5"/>
              </svg>
            </div>
            <div id="avatar-spinner" class="hidden absolute inset-0 rounded-xl bg-black/60 flex items-center justify-center">
              <div class="w-5 h-5 border-2 border-emerald-400 border-t-transparent rounded-full animate-spin"></div>
            </div>
          </div>
          <input id="avatar-file" type="file" accept="image/*" class="hidden"/>
          <input type="hidden" id="avatar-hidden" name="avatar" value="{{ user.avatar }}"/>
          {% if user.role === 'admin' %}
            <span class="px-1.5 py-0.5 bg-amber-500/10 border border-amber-500/30 rounded text-amber-400 font-mono text-[9px] uppercase tracking-widest">admin</span>
          {% endif %}
          <p class="text-[9px] font-mono text-slate-700 text-center">click para cambiar</p>
        </div>

        {# Identity #}
        <div class="flex-1 min-w-0 flex flex-col gap-4">

          {# Nombre #}
          <div class="flex flex-col gap-1.5">
            <label class="text-[10px] font-mono text-emerald-400 uppercase tracking-widest">// nombre</label>
            <input type="text" name="name" value="{{ user.name }}" required
                   class="bg-[#0a0a0f] border border-slate-700 rounded-lg px-4 py-2.5 text-sm font-mono text-slate-200 focus:outline-none focus:border-emerald-500/50 focus:ring-1 focus:ring-emerald-500/20 transition-all"/>
          </div>

          {# Email — solo lectura #}
          <div class="flex flex-col gap-1.5">
            <label class="text-[10px] font-mono text-slate-600 uppercase tracking-widest">// email <span class="text-slate-700 normal-case">(no editable)</span></label>
            <input type="text" value="{{ user.email }}" disabled
                   class="bg-transparent border border-slate-800/50 rounded-lg px-4 py-2.5 text-sm font-mono text-slate-600 cursor-not-allowed"/>
          </div>

          {# Bio #}
          <div class="flex flex-col gap-1.5">
            <label class="text-[10px] font-mono text-emerald-400 uppercase tracking-widest">// bio</label>
            <textarea name="bio" rows="3" placeholder="// cuéntanos algo sobre ti"
                      class="bg-[#0a0a0f] border border-slate-700 rounded-lg px-4 py-2.5 text-sm font-mono text-slate-300 focus:outline-none focus:border-emerald-500/50 focus:ring-1 focus:ring-emerald-500/20 transition-all placeholder-slate-700 resize-none leading-relaxed">{{ user.bio }}</textarea>
          </div>

          {# Social links #}
          <div class="flex flex-col gap-2">
            <label class="text-[10px] font-mono text-emerald-400 uppercase tracking-widest">// social links</label>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">

              <div class="flex items-center gap-2 bg-[#0a0a0f] border border-slate-800 rounded-lg px-3 py-2">
                <svg class="w-3.5 h-3.5 fill-current text-slate-600 shrink-0" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.2 11.38.6.11.82-.26.82-.58v-2.03c-3.34.72-4.04-1.61-4.04-1.61-.54-1.38-1.33-1.75-1.33-1.75-1.09-.74.08-.73.08-.73 1.2.09 1.84 1.24 1.84 1.24 1.07 1.83 2.8 1.3 3.49 1 .1-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.14-.3-.54-1.52.1-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 3-.4c1.02 0 2.04.13 3 .4 2.28-1.55 3.29-1.23 3.29-1.23.65 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.81 5.63-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.21.7.82.58C20.56 21.8 24 17.3 24 12c0-6.63-5.37-12-12-12z"/></svg>
                <input type="text" name="socialLinks[github]" value="{{ user.socialLinks.github }}" placeholder="GitHub URL"
                       class="bg-transparent text-xs font-mono text-slate-400 focus:outline-none placeholder-slate-700 w-full focus:text-slate-200 transition-colors"/>
              </div>

              <div class="flex items-center gap-2 bg-[#0a0a0f] border border-slate-800 rounded-lg px-3 py-2">
                <svg class="w-3.5 h-3.5 fill-current text-slate-600 shrink-0" viewBox="0 0 24 24"><path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.37V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zm1.78 13.02H3.56V9h3.56v11.45zM22.23 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.46c.98 0 1.77-.77 1.77-1.72V1.72C24 .77 23.21 0 22.23 0z"/></svg>
                <input type="text" name="socialLinks[linkedin]" value="{{ user.socialLinks.linkedin }}" placeholder="LinkedIn URL"
                       class="bg-transparent text-xs font-mono text-slate-400 focus:outline-none placeholder-slate-700 w-full focus:text-slate-200 transition-colors"/>
              </div>

              <div class="flex items-center gap-2 bg-[#0a0a0f] border border-slate-800 rounded-lg px-3 py-2">
                <svg class="w-3.5 h-3.5 fill-current text-slate-600 shrink-0" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.747l7.73-8.835L1.254 2.25H8.08l4.259 5.63 5.905-5.63zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                <input type="text" name="socialLinks[twitter]" value="{{ user.socialLinks.twitter }}" placeholder="Twitter / X URL"
                       class="bg-transparent text-xs font-mono text-slate-400 focus:outline-none placeholder-slate-700 w-full focus:text-slate-200 transition-colors"/>
              </div>

              <div class="flex items-center gap-2 bg-[#0a0a0f] border border-slate-800 rounded-lg px-3 py-2">
                <svg class="w-3.5 h-3.5 stroke-current fill-none text-slate-600 shrink-0" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                <input type="text" name="socialLinks[website]" value="{{ user.socialLinks.website }}" placeholder="Website URL"
                       class="bg-transparent text-xs font-mono text-slate-400 focus:outline-none placeholder-slate-700 w-full focus:text-slate-200 transition-colors"/>
              </div>

            </div>
          </div>

        </div>

        {# Meta stats #}
        <div class="flex flex-row sm:flex-col gap-3 shrink-0 text-right">
          <div class="bg-[#0a0a0f] border border-slate-800 rounded-lg px-4 py-2.5 text-center min-w-[80px]">
            <p class="text-lg font-mono font-bold text-emerald-400">{{ portfolios | length }}</p>
            <p class="text-[10px] font-mono text-slate-600 uppercase tracking-widest mt-0.5">porfolios</p>
          </div>
          <div class="bg-[#0a0a0f] border border-slate-800 rounded-lg px-4 py-2.5 text-center min-w-[80px]">
            <p class="text-lg font-mono font-bold text-slate-300">{{ user.skills | length }}</p>
            <p class="text-[10px] font-mono text-slate-600 uppercase tracking-widest mt-0.5">skills</p>
          </div>
          <div class="bg-[#0a0a0f] border border-slate-800 rounded-lg px-4 py-2.5 text-center min-w-[80px]">
            <p class="text-lg font-mono font-bold text-slate-300">{{ user.languages | length }}</p>
            <p class="text-[10px] font-mono text-slate-600 uppercase tracking-widest mt-0.5">lenguajes</p>
          </div>
        </div>

      </div>
    </div>

    {# ── SKILLS + LANGUAGES ───────────────────────────────────────── #}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

      {# Skills / Tecnologías — multi-select #}
      <div class="bg-[#0f0f18] border border-slate-800 rounded-2xl p-6 flex flex-col gap-4">
        <label class="text-xs font-mono text-emerald-400 uppercase tracking-widest">// tecnologías</label>
        <div class="relative">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-500 pointer-events-none" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
          <input id="skill-search" type="text" placeholder="Buscar tecnología..." autocomplete="off"
                 class="w-full bg-[#0a0a0f] border border-slate-800 rounded-lg pl-9 pr-4 py-2.5 text-sm font-mono text-slate-200 placeholder-slate-600 focus:outline-none focus:border-emerald-500/50 focus:ring-1 focus:ring-emerald-500/20 transition-all"/>
          <div id="skill-suggestions" class="hidden absolute z-50 w-full mt-1 bg-[#0f0f18] border border-slate-700 rounded-lg overflow-hidden shadow-xl max-h-48 overflow-y-auto"></div>
        </div>
        <div id="skill-selected" class="flex flex-wrap gap-2">
          {% for skill in user.skills %}
            <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-mono border border-emerald-500/40 text-emerald-400 bg-emerald-500/10" data-id="{{ skill._id }}">
              {{ skill.name }}
              <button type="button" class="ml-0.5 hover:text-white remove-skill-btn">×</button>
            </span>
            <input type="hidden" name="skills" value="{{ skill._id }}"/>
          {% endfor %}
        </div>
      </div>

      {# Languages — multi-select #}
      <div class="bg-[#0f0f18] border border-slate-800 rounded-2xl p-6 flex flex-col gap-4">
        <label class="text-xs font-mono text-violet-400 uppercase tracking-widest">// lenguajes</label>
        <div class="relative">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-500 pointer-events-none" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
          <input id="lang-search" type="text" placeholder="Buscar lenguaje..." autocomplete="off"
                 class="w-full bg-[#0a0a0f] border border-slate-800 rounded-lg pl-9 pr-4 py-2.5 text-sm font-mono text-slate-200 placeholder-slate-600 focus:outline-none focus:border-violet-500/50 focus:ring-1 focus:ring-violet-500/20 transition-all"/>
          <div id="lang-suggestions" class="hidden absolute z-50 w-full mt-1 bg-[#0f0f18] border border-slate-700 rounded-lg overflow-hidden shadow-xl max-h-48 overflow-y-auto"></div>
        </div>
        <div id="lang-selected" class="flex flex-wrap gap-2">
          {% for lang in user.languages %}
            <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-mono border border-violet-500/40 text-violet-400 bg-violet-500/10" data-id="{{ lang._id }}">
              {{ lang.name }}
              <button type="button" class="ml-0.5 hover:text-white remove-lang-btn">×</button>
            </span>
            <input type="hidden" name="languages" value="{{ lang._id }}"/>
          {% endfor %}
        </div>
      </div>

    </div>

    {# ── INVITED BY ───────────────────────────────────────────────── #}
    {% if user.invitedBy %}
    <div class="bg-[#0f0f18] border border-slate-800/60 rounded-xl px-5 py-3 flex items-center gap-3">
      <span class="text-xs font-mono text-slate-600">// invitado por</span>
      <a href="/perfil/{{ user.invitedBy._id }}" class="flex items-center gap-2 group">
        {% if user.invitedBy.avatar %}
          <img src="{{ user.invitedBy.avatar }}" class="w-5 h-5 rounded object-cover border border-slate-700 opacity-70 group-hover:opacity-100 transition-opacity" alt=""/>
        {% else %}
          <span class="w-5 h-5 rounded bg-slate-800 border border-slate-700 flex items-center justify-center text-[9px] font-mono text-slate-500 group-hover:text-slate-300 transition-colors">{{ user.invitedBy.name[0] | upper }}</span>
        {% endif %}
        <span class="text-xs font-mono text-slate-500 group-hover:text-emerald-400 transition-colors">{{ user.invitedBy.name }}</span>
      </a>
    </div>
    {% endif %}

    {# ── PORTFOLIOS ───────────────────────────────────────────────── #}
    <div class="flex flex-col gap-5">
      <div class="flex items-center justify-between">
        <label class="text-xs font-mono text-emerald-400 uppercase tracking-widest">// porfolios</label>
        <span class="text-xs font-mono text-slate-600">{{ portfolios | length }} publicados</span>
      </div>

      {% if portfolios and portfolios | length > 0 %}
        <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-5">
          {% for portfolio in portfolios %}
          <a href="/porfolios/{{ portfolio._id }}"
             class="group bg-[#0f0f18] border border-slate-800 rounded-xl overflow-hidden hover:border-slate-600 hover:shadow-[0_0_24px_-4px_rgba(16,185,129,0.08)] transition-all duration-300 flex flex-col">
            <div class="aspect-video bg-[#0a0a0f] relative overflow-hidden">
              {% if portfolio.media and portfolio.media | length > 0 %}
                <img src="{{ portfolio.media[0].url }}" alt="{{ portfolio.title }}"
                     class="w-full h-full object-cover opacity-80 group-hover:opacity-100 group-hover:scale-[1.02] transition-all duration-500"/>
              {% else %}
                <div class="w-full h-full flex items-center justify-center">
                  <span class="font-mono text-xs text-slate-700">// sin preview</span>
                </div>
              {% endif %}
              {% if portfolio.featured %}
                <span class="absolute top-2.5 right-2.5 px-2 py-0.5 bg-emerald-500/10 border border-emerald-500/30 rounded text-emerald-400 font-mono text-[9px] uppercase tracking-widest backdrop-blur-sm">★ destacado</span>
              {% endif %}
            </div>
            <div class="p-4 flex flex-col gap-2.5 flex-1">
              <h3 class="text-sm font-mono font-semibold text-slate-200 group-hover:text-emerald-400 transition-colors leading-snug line-clamp-2">{{ portfolio.title }}</h3>
              {% if portfolio.description %}
                <p class="text-xs text-slate-500 leading-relaxed line-clamp-2">{{ portfolio.description }}</p>
              {% endif %}
              <div class="flex flex-wrap gap-1.5 mt-auto pt-1">
                {% for tech in portfolio.technologies | slice(0, 4) %}
                  <span class="px-2 py-0.5 bg-[#0a0a0f] border border-slate-800 rounded text-[10px] font-mono text-slate-400">{{ tech.name }}</span>
                {% endfor %}
                {% if portfolio.technologies | length > 4 %}
                  <span class="px-2 py-0.5 text-[10px] font-mono text-slate-600">+{{ portfolio.technologies | length - 4 }}</span>
                {% endif %}
              </div>
            </div>
          </a>
          {% endfor %}
        </div>
      {% else %}
        <div class="bg-[#0f0f18] border border-slate-800/60 border-dashed rounded-xl py-16 flex flex-col items-center justify-center gap-3">
          <span class="font-mono text-slate-700 text-sm">// ningún porfolio publicado aún</span>
        </div>
      {% endif %}
    </div>

    {# ── GUARDAR + MEMBER SINCE ───────────────────────────────────── #}
    <div class="flex items-center justify-between pb-2">
      <div class="flex items-center gap-2 text-[10px] font-mono text-slate-700">
        <span class="w-1.5 h-1.5 rounded-full bg-slate-800 inline-block"></span>
        miembro desde {{ memberSince }}
      </div>
      <button type="submit"
              class="px-5 py-2 bg-emerald-500/10 border border-emerald-500/30 rounded-lg text-emerald-400 font-mono text-xs uppercase tracking-widest hover:bg-emerald-500/20 transition-all">
        Guardar cambios
      </button>
    </div>

  </div>
  </form>
</div>

<script>
  async function generarInvitacion() {
    const res = await fetch('/api/invitaciones/siguiente')
    const data = await res.json()
    if (data.key) {
      document.getElementById('invitationKey').value = data.key
    }
  }

  // ── Upload de avatar ─────────────────────────────────────────────
  document.getElementById('avatar-file').addEventListener('change', async (e) => {
    const file = e.target.files[0]
    if (!file) return
    const spinner = document.getElementById('avatar-spinner')
    spinner.classList.remove('hidden')
    spinner.classList.add('flex')
    try {
      const formData = new FormData()
      formData.append('avatar', file)
      const res  = await fetch('/api/usuarios/{{ user._id }}/avatar', { method: 'POST', body: formData })
      const data = await res.json()
      if (!res.ok) throw new Error(data.error)
      document.getElementById('avatar-preview').src = data.url
      document.getElementById('avatar-hidden').value = data.url
    } catch (err) {
      console.error(err)
      alert('Error al subir la imagen: ' + err.message)
    } finally {
      spinner.classList.add('hidden')
      spinner.classList.remove('flex')
      e.target.value = ''
    }
  })

  // ── Multi-select para skills y lenguajes ─────────────────────────
  let debounceTimer = null
  function debounce(fn, ms = 300) { clearTimeout(debounceTimer); debounceTimer = setTimeout(fn, ms) }

  async function fetchSuggestions(endpoint, query, dropdownEl, onSelect) {
    if (!query.trim()) { dropdownEl.classList.add('hidden'); return }
    try {
      const res  = await fetch(`/api/${endpoint}/search?q=${encodeURIComponent(query)}`)
      const data = await res.json()
      if (!data.result?.length) {
        dropdownEl.innerHTML = `<p class="px-4 py-3 text-xs font-mono text-slate-600">Sin resultados</p>`
        dropdownEl.classList.remove('hidden')
        return
      }
      dropdownEl.innerHTML = data.result.map(item => `
        <button type="button" class="w-full text-left px-4 py-2.5 text-sm font-mono text-slate-300 hover:bg-emerald-500/10 hover:text-emerald-400 transition-colors flex items-center justify-between"
          data-id="${item._id}" data-name="${item.name}">
          <span>${item.name}</span>
          <span class="text-[10px] text-slate-600">${item.category}</span>
        </button>`).join('')
      dropdownEl.querySelectorAll('button').forEach(btn => {
        btn.addEventListener('click', () => {
          onSelect({ _id: btn.dataset.id, name: btn.dataset.name })
          dropdownEl.classList.add('hidden')
        })
      })
      dropdownEl.classList.remove('hidden')
    } catch (err) { console.error(err) }
  }

  function addTag(container, item, colorClass, inputName) {
    if ([...container.querySelectorAll('[data-id]')].find(el => el.dataset.id === item._id)) return
    const tag = document.createElement('span')
    tag.className = `inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-mono border ${colorClass}`
    tag.dataset.id = item._id
    tag.innerHTML = `${item.name}<button type="button" class="ml-0.5 hover:text-white remove-tag-dyn">×</button>`
    const hidden = document.createElement('input')
    hidden.type  = 'hidden'
    hidden.name  = inputName
    hidden.value = item._id
    hidden.dataset.tagId = item._id
    tag.querySelector('.remove-tag-dyn').addEventListener('click', () => {
      tag.remove()
      document.querySelector(`input[name="${inputName}"][data-tag-id="${item._id}"]`)?.remove()
    })
    container.appendChild(tag)
    container.appendChild(hidden)
  }

  // Bind existing remove buttons (for pre-populated items)
  document.querySelectorAll('.remove-skill-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const tag = btn.closest('span')
      const id  = tag.dataset.id
      tag.remove()
      document.querySelector(`input[name="skills"][value="${id}"]`)?.remove()
    })
  })
  document.querySelectorAll('.remove-lang-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const tag = btn.closest('span')
      const id  = tag.dataset.id
      tag.remove()
      document.querySelector(`input[name="languages"][value="${id}"]`)?.remove()
    })
  })

  const skillSearch = document.getElementById('skill-search')
  const skillSugg   = document.getElementById('skill-suggestions')
  const skillSel    = document.getElementById('skill-selected')
  const langSearch  = document.getElementById('lang-search')
  const langSugg    = document.getElementById('lang-suggestions')
  const langSel     = document.getElementById('lang-selected')

  skillSearch.addEventListener('input', () => {
    debounce(() => fetchSuggestions('technologies', skillSearch.value, skillSugg, (item) => {
      addTag(skillSel, item, 'border-emerald-500/40 text-emerald-400 bg-emerald-500/10', 'skills')
      skillSearch.value = ''
    }))
  })

  langSearch.addEventListener('input', () => {
    debounce(() => fetchSuggestions('languages', langSearch.value, langSugg, (item) => {
      addTag(langSel, item, 'border-violet-500/40 text-violet-400 bg-violet-500/10', 'languages')
      langSearch.value = ''
    }))
  })

  document.addEventListener('click', (e) => {
    if (!skillSearch.contains(e.target) && !skillSugg.contains(e.target)) skillSugg.classList.add('hidden')
    if (!langSearch.contains(e.target)  && !langSugg.contains(e.target))  langSugg.classList.add('hidden')
  })
</script>

{% endblock %}
