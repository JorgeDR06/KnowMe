{% extends "base.njk" %}

{% block titulo %}{{ "Editar" if porfolio else "Nuevo" }} Porfolio — KnowMe{% endblock %}

{% block contenido %}

<div class="min-h-screen bg-[#0a0a0f] text-slate-300">
  <div class="max-w-[900px] mx-auto px-6 py-10">

    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 text-xs font-mono text-slate-600 mb-8">
      <a href="/porfolios" class="hover:text-emerald-400 transition-colors">porfolios</a>
      <span>/</span>
      <span class="text-slate-400">{{ "editar" if porfolio else "nuevo" }}</span>
    </div>

    <h1 class="text-2xl font-bold text-white mb-8">
      {{ "Editar porfolio" if porfolio else "Nuevo porfolio" }}
    </h1>

    <div class="flex flex-col gap-8">

      <!-- ── Información básica ─────────────────────────────────── -->
      <section class="bg-[#0f0f18] border border-slate-800 rounded-xl p-6 flex flex-col gap-5">
        <p class="text-xs font-mono text-emerald-400 uppercase tracking-widest">// información básica</p>

        <div>
          <label class="block text-xs font-mono text-slate-400 mb-2">Título *</label>
          <input
            id="input-title"
            type="text"
            placeholder="Nombre de tu proyecto"
            value="{{ porfolio.title if porfolio else '' }}"
            class="w-full bg-[#0a0a0f] border border-slate-800 rounded-lg px-4 py-2.5 text-sm text-slate-200 placeholder-slate-600 focus:outline-none focus:border-emerald-500/50 focus:ring-1 focus:ring-emerald-500/20 transition-all font-mono"
          />
        </div>

        <div>
          <label class="block text-xs font-mono text-slate-400 mb-2">Descripción *</label>
          <textarea
            id="input-description"
            rows="5"
            placeholder="Describe tu proyecto..."
            class="w-full bg-[#0a0a0f] border border-slate-800 rounded-lg px-4 py-2.5 text-sm text-slate-200 placeholder-slate-600 focus:outline-none focus:border-emerald-500/50 focus:ring-1 focus:ring-emerald-500/20 transition-all font-mono resize-none"
          >{{ porfolio.description if porfolio else '' }}</textarea>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-mono text-slate-400 mb-2">GitHub</label>
            <input
              id="input-github"
              type="url"
              placeholder="https://github.com/..."
              value="{{ porfolio.githubRepo if porfolio else '' }}"
              class="w-full bg-[#0a0a0f] border border-slate-800 rounded-lg px-4 py-2.5 text-sm text-slate-200 placeholder-slate-600 focus:outline-none focus:border-emerald-500/50 focus:ring-1 focus:ring-emerald-500/20 transition-all font-mono"
            />
          </div>
          <div>
            <label class="block text-xs font-mono text-slate-400 mb-2">Live Demo</label>
            <input
              id="input-demo"
              type="url"
              placeholder="https://..."
              value="{{ porfolio.liveDemo if porfolio else '' }}"
              class="w-full bg-[#0a0a0f] border border-slate-800 rounded-lg px-4 py-2.5 text-sm text-slate-200 placeholder-slate-600 focus:outline-none focus:border-emerald-500/50 focus:ring-1 focus:ring-emerald-500/20 transition-all font-mono"
            />
          </div>
        </div>

        <div class="flex items-center gap-3">
          <button
            id="featured-toggle"
            onclick="toggleFeatured(this)"
            class="flex items-center gap-3 bg-[#0a0a0f] border border-slate-800 rounded-lg px-4 py-2.5 hover:border-emerald-500/40 transition-all"
          >
            <div id="featured-track" class="w-8 h-4 rounded-full bg-slate-700 relative transition-all duration-200 shrink-0 {{ 'bg-emerald-500' if porfolio and porfolio.featured else '' }}">
              <div id="featured-knob" class="w-3 h-3 rounded-full absolute top-0.5 transition-all duration-200 {{ 'bg-white translate-x-4 left-0.5' if porfolio and porfolio.featured else 'bg-slate-400 left-0.5' }}"></div>
            </div>
            <span class="font-mono text-xs text-slate-400">Destacado</span>
          </button>
          <input type="hidden" id="input-featured" value="{{ 'true' if porfolio and porfolio.featured else 'false' }}"/>
        </div>
      </section>

      <!-- ── Media ──────────────────────────────────────────────── -->
      <section class="bg-[#0f0f18] border border-slate-800 rounded-xl p-6 flex flex-col gap-5">
        <p class="text-xs font-mono text-emerald-400 uppercase tracking-widest">// imágenes y vídeos</p>

        <!-- Zona de subida -->
        <div
          id="drop-zone"
          class="border-2 border-dashed border-slate-700 rounded-xl p-8 text-center hover:border-emerald-500/40 transition-all cursor-pointer"
          onclick="document.getElementById('file-input').click()"
        >
          <svg class="w-10 h-10 text-slate-600 mx-auto mb-3" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13.5"/>
          </svg>
          <p class="text-sm text-slate-500 font-mono">Haz click o arrastra archivos aquí</p>
          <p class="text-xs text-slate-600 font-mono mt-1">JPG, PNG, GIF, WebP, MP4, MOV</p>
          <input id="file-input" type="file" accept="image/*,video/*" multiple class="hidden"/>
        </div>

        <!-- Preview media -->
        <div id="media-preview" class="grid grid-cols-3 gap-3">
          {% if porfolio and porfolio.media %}
            {% for item in porfolio.media %}
            <div class="media-item relative aspect-video bg-[#0a0a0f] rounded-lg overflow-hidden border border-slate-800 group" data-url="{{ item.url }}" data-public-id="{{ item.publicId }}" data-type="{{ item.type }}">
              {% if item.type == 'video' %}
                <video src="{{ item.url }}" class="w-full h-full object-cover"></video>
              {% else %}
                <img src="{{ item.url }}" class="w-full h-full object-cover"/>
              {% endif %}
              <button onclick="removeMedia(this)" class="absolute top-1 right-1 w-6 h-6 bg-red-500/80 rounded-full text-white text-xs hidden group-hover:flex items-center justify-center">×</button>
            </div>
            {% endfor %}
          {% endif %}
        </div>

        <div id="upload-progress" class="hidden">
          <div class="flex items-center gap-3 text-xs font-mono text-slate-500">
            <div class="w-4 h-4 border-2 border-emerald-500 border-t-transparent rounded-full animate-spin"></div>
            Subiendo archivo...
          </div>
        </div>
      </section>

      <!-- ── Tecnologías ────────────────────────────────────────── -->
      <section class="bg-[#0f0f18] border border-slate-800 rounded-xl p-6 flex flex-col gap-4">
        <p class="text-xs font-mono text-emerald-400 uppercase tracking-widest">// tecnologías</p>
        <div class="relative">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
          <input
            id="tech-search"
            type="text"
            placeholder="Buscar tecnología..."
            autocomplete="off"
            class="w-full bg-[#0a0a0f] border border-slate-800 rounded-lg pl-9 pr-4 py-2.5 text-sm text-slate-200 placeholder-slate-600 focus:outline-none focus:border-emerald-500/50 focus:ring-1 focus:ring-emerald-500/20 transition-all font-mono"
          />
          <div id="tech-suggestions" class="hidden absolute z-50 w-full mt-1 bg-[#0f0f18] border border-slate-700 rounded-lg overflow-hidden shadow-xl max-h-48 overflow-y-auto"></div>
        </div>
        <div id="tech-selected" class="flex flex-wrap gap-2">
          {% if porfolio and porfolio.technologies %}
            {% for tech in porfolio.technologies %}
            <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-mono border border-emerald-500/40 text-emerald-400 bg-emerald-500/10" data-id="{{ tech._id }}">
              {{ tech.name }}
              <button onclick="removeTag(this, 'tech')" class="ml-0.5 hover:text-white">×</button>
            </span>
            {% endfor %}
          {% endif %}
        </div>
      </section>

      <!-- ── Lenguajes ──────────────────────────────────────────── -->
      <section class="bg-[#0f0f18] border border-slate-800 rounded-xl p-6 flex flex-col gap-4">
        <p class="text-xs font-mono text-violet-400 uppercase tracking-widest">// lenguajes</p>
        <div class="relative">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
          <input
            id="lang-search"
            type="text"
            placeholder="Buscar lenguaje..."
            autocomplete="off"
            class="w-full bg-[#0a0a0f] border border-slate-800 rounded-lg pl-9 pr-4 py-2.5 text-sm text-slate-200 placeholder-slate-600 focus:outline-none focus:border-emerald-500/50 focus:ring-1 focus:ring-emerald-500/20 transition-all font-mono"
          />
          <div id="lang-suggestions" class="hidden absolute z-50 w-full mt-1 bg-[#0f0f18] border border-slate-700 rounded-lg overflow-hidden shadow-xl max-h-48 overflow-y-auto"></div>
        </div>
        <div id="lang-selected" class="flex flex-wrap gap-2">
          {% if porfolio and porfolio.languages %}
            {% for lang in porfolio.languages %}
            <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-mono border border-violet-500/40 text-violet-400 bg-violet-500/10" data-id="{{ lang._id }}">
              {{ lang.name }}
              <button onclick="removeTag(this, 'lang')" class="ml-0.5 hover:text-white">×</button>
            </span>
            {% endfor %}
          {% endif %}
        </div>
      </section>

      <!-- ── Snippets de código ─────────────────────────────────── -->
      <section class="bg-[#0f0f18] border border-slate-800 rounded-xl p-6 flex flex-col gap-5">
        <div class="flex items-center justify-between">
          <p class="text-xs font-mono text-emerald-400 uppercase tracking-widest">// snippets de código</p>
          <button onclick="addSnippet()" class="text-xs font-mono text-emerald-400 hover:text-emerald-300 border border-emerald-500/30 px-3 py-1.5 rounded-lg hover:border-emerald-500/60 transition-all">
            + añadir snippet
          </button>
        </div>
        <div id="snippets-container" class="flex flex-col gap-4">
          {% if porfolio and porfolio.codeSnippets %}
            {% for snippet in porfolio.codeSnippets %}
            <div class="snippet-item bg-[#0a0a0f] border border-slate-800 rounded-lg p-4 flex flex-col gap-3">
              <div class="flex items-center gap-3">
                <input type="text" placeholder="Título del snippet" value="{{ snippet.title }}"
                  class="snippet-title flex-1 bg-[#0f0f18] border border-slate-800 rounded-lg px-3 py-2 text-sm text-slate-200 placeholder-slate-600 focus:outline-none focus:border-emerald-500/50 font-mono"/>
                <input type="text" placeholder="Lenguaje" value="{{ snippet.language }}"
                  class="snippet-language w-32 bg-[#0f0f18] border border-slate-800 rounded-lg px-3 py-2 text-sm text-slate-200 placeholder-slate-600 focus:outline-none focus:border-emerald-500/50 font-mono"/>
                <button onclick="removeSnippet(this)" class="text-slate-600 hover:text-red-400 transition-colors text-lg leading-none">×</button>
              </div>
              <textarea placeholder="Código..." rows="6"
                class="snippet-code w-full bg-[#0f0f18] border border-slate-800 rounded-lg px-3 py-2 text-sm text-slate-200 placeholder-slate-600 focus:outline-none focus:border-emerald-500/50 font-mono resize-none">{{ snippet.code }}</textarea>
            </div>
            {% endfor %}
          {% endif %}
        </div>
      </section>

      <!-- ── Botones ────────────────────────────────────────────── -->
      <div class="flex items-center justify-between pb-10">
        <a href="/porfolios" class="text-sm font-mono text-slate-500 hover:text-slate-300 transition-colors">← cancelar</a>
        <div class="flex gap-3">
          <div id="save-error" class="hidden text-xs font-mono text-red-400 self-center"></div>
          <button onclick="savePorfolio()" id="save-btn"
            class="px-6 py-2.5 bg-emerald-500 hover:bg-emerald-400 text-[#0a0a0f] font-mono font-bold text-sm rounded-lg transition-all flex items-center gap-2">
            <span id="save-label">{{ "Guardar cambios" if porfolio else "Crear porfolio" }}</span>
          </button>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
  // ── Estado ────────────────────────────────────────────────────────────────
  const IS_EDIT     = {{ 'true' if porfolio else 'false' }}
  const PORFOLIO_ID = '{{ porfolio._id if porfolio else "" }}'
  let mediaItems    = []
  let debounceTimer = null

  // Cargar media existente
  document.querySelectorAll('.media-item').forEach(el => {
    mediaItems.push({
      url:       el.dataset.url,
      publicId:  el.dataset.publicId,
      type:      el.dataset.type
    })
  })

  // ── Featured toggle ───────────────────────────────────────────────────────
  window.toggleFeatured = function(btn) {
    const track  = document.getElementById('featured-track')
    const knob   = document.getElementById('featured-knob')
    const input  = document.getElementById('input-featured')
    const active = input.value === 'true'

    if (active) {
      track.classList.replace('bg-emerald-500', 'bg-slate-700')
      knob.classList.remove('translate-x-4')
      knob.classList.replace('bg-white', 'bg-slate-400')
      input.value = 'false'
    } else {
      track.classList.replace('bg-slate-700', 'bg-emerald-500')
      knob.classList.add('translate-x-4')
      knob.classList.replace('bg-slate-400', 'bg-white')
      input.value = 'true'
    }
  }

  // ── Subida de archivos ────────────────────────────────────────────────────
  document.getElementById('file-input').addEventListener('change', async (e) => {
    for (const file of e.target.files) {
      await uploadFile(file)
    }
    e.target.value = ''
  })

  const dropZone = document.getElementById('drop-zone')
  dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('border-emerald-500/60') })
  dropZone.addEventListener('dragleave', () => dropZone.classList.remove('border-emerald-500/60'))
  dropZone.addEventListener('drop', async (e) => {
    e.preventDefault()
    dropZone.classList.remove('border-emerald-500/60')
    for (const file of e.dataTransfer.files) {
      await uploadFile(file)
    }
  })

  async function uploadFile(file) {
    const progress = document.getElementById('upload-progress')
    progress.classList.remove('hidden')

    const formData = new FormData()
    formData.append('file', file)

    try {
      const res  = await fetch('/api/porfolios/upload', {
        method: 'POST',
        body: formData
      })
      const data = await res.json()

      if (!res.ok) throw new Error(data.error)

      mediaItems.push({ url: data.url, publicId: data.publicId, type: data.type })
      renderMediaPreview()
    } catch (err) {
      console.error(err)
      showError('Error al subir el archivo: ' + err.message)
    } finally {
      progress.classList.add('hidden')
    }
  }

  function renderMediaPreview() {
    const container = document.getElementById('media-preview')
    container.innerHTML = mediaItems.map((item, i) => `
      <div class="relative aspect-video bg-[#0a0a0f] rounded-lg overflow-hidden border border-slate-800 group">
        ${item.type === 'video'
          ? `<video src="${item.url}" class="w-full h-full object-cover"></video>`
          : `<img src="${item.url}" class="w-full h-full object-cover"/>`
        }
        <button onclick="removeMediaByIndex(${i})" class="absolute top-1 right-1 w-6 h-6 bg-red-500/80 rounded-full text-white text-xs hidden group-hover:flex items-center justify-center">×</button>
      </div>
    `).join('')
  }

  window.removeMediaByIndex = function(index) {
    mediaItems.splice(index, 1)
    renderMediaPreview()
  }

  window.removeMedia = function(btn) {
    btn.closest('.media-item').remove()
  }

  // ── Autocompletado ────────────────────────────────────────────────────────
  function debounce(fn, ms = 300) {
    clearTimeout(debounceTimer)
    debounceTimer = setTimeout(fn, ms)
  }

  async function fetchSuggestions(endpoint, query, dropdownEl, onSelect) {
    if (!query.trim()) { dropdownEl.classList.add('hidden'); return }
    try {
      const res  = await fetch(`/api/${endpoint}/search?q=${encodeURIComponent(query)}`)
      const data = await res.json()
      if (!data.result?.length) {
        dropdownEl.innerHTML = `<p class="px-4 py-3 text-xs font-mono text-slate-600">Sin resultados</p>`
        dropdownEl.classList.remove('hidden')
        return
      }
      dropdownEl.innerHTML = data.result.map(item => `
        <button class="w-full text-left px-4 py-2.5 text-sm font-mono text-slate-300 hover:bg-emerald-500/10 hover:text-emerald-400 transition-colors flex items-center justify-between"
          data-id="${item._id}" data-name="${item.name}">
          <span>${item.name}</span>
          <span class="text-[10px] text-slate-600">${item.category}</span>
        </button>`).join('')
      dropdownEl.querySelectorAll('button').forEach(btn => {
        btn.addEventListener('click', () => {
          onSelect({ _id: btn.dataset.id, name: btn.dataset.name })
          dropdownEl.classList.add('hidden')
        })
      })
      dropdownEl.classList.remove('hidden')
    } catch (err) { console.error(err) }
  }

  function addTag(container, item, colorClass) {
    const existing = [...container.querySelectorAll('[data-id]')].find(el => el.dataset.id === item._id)
    if (existing) return
    const tag = document.createElement('span')
    tag.className = `inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-mono border ${colorClass}`
    tag.dataset.id = item._id
    tag.innerHTML = `${item.name}<button class="ml-0.5 hover:text-white remove-tag-btn">×</button>`
    tag.querySelector('.remove-tag-btn').addEventListener('click', () => tag.remove())
    container.appendChild(tag)
  }

  window.removeTag = function(btn, type) {
    btn.closest('span').remove()
  }

  const techSearch  = document.getElementById('tech-search')
  const techSugg    = document.getElementById('tech-suggestions')
  const techSel     = document.getElementById('tech-selected')
  const langSearch  = document.getElementById('lang-search')
  const langSugg    = document.getElementById('lang-suggestions')
  const langSel     = document.getElementById('lang-selected')

  techSearch.addEventListener('input', () => {
    debounce(() => fetchSuggestions('technologies', techSearch.value, techSugg, (item) => {
      addTag(techSel, item, 'border-emerald-500/40 text-emerald-400 bg-emerald-500/10')
      techSearch.value = ''
    }))
  })

  langSearch.addEventListener('input', () => {
    debounce(() => fetchSuggestions('languages', langSearch.value, langSugg, (item) => {
      addTag(langSel, item, 'border-violet-500/40 text-violet-400 bg-violet-500/10')
      langSearch.value = ''
    }))
  })

  document.addEventListener('click', (e) => {
    if (!techSearch.contains(e.target) && !techSugg.contains(e.target)) techSugg.classList.add('hidden')
    if (!langSearch.contains(e.target) && !langSugg.contains(e.target)) langSugg.classList.add('hidden')
  })

  // ── Snippets ──────────────────────────────────────────────────────────────
  window.addSnippet = function() {
    const container = document.getElementById('snippets-container')
    const div = document.createElement('div')
    div.className = 'snippet-item bg-[#0a0a0f] border border-slate-800 rounded-lg p-4 flex flex-col gap-3'
    div.innerHTML = `
      <div class="flex items-center gap-3">
        <input type="text" placeholder="Título del snippet"
          class="snippet-title flex-1 bg-[#0f0f18] border border-slate-800 rounded-lg px-3 py-2 text-sm text-slate-200 placeholder-slate-600 focus:outline-none focus:border-emerald-500/50 font-mono"/>
        <input type="text" placeholder="Lenguaje"
          class="snippet-language w-32 bg-[#0f0f18] border border-slate-800 rounded-lg px-3 py-2 text-sm text-slate-200 placeholder-slate-600 focus:outline-none focus:border-emerald-500/50 font-mono"/>
        <button onclick="removeSnippet(this)" class="text-slate-600 hover:text-red-400 transition-colors text-lg leading-none">×</button>
      </div>
      <textarea placeholder="Código..." rows="6"
        class="snippet-code w-full bg-[#0f0f18] border border-slate-800 rounded-lg px-3 py-2 text-sm text-slate-200 placeholder-slate-600 focus:outline-none focus:border-emerald-500/50 font-mono resize-none"></textarea>
    `
    container.appendChild(div)
  }

  window.removeSnippet = function(btn) {
    btn.closest('.snippet-item').remove()
  }

  // ── Guardar ───────────────────────────────────────────────────────────────
  function showError(msg) {
    const el = document.getElementById('save-error')
    el.textContent = msg
    el.classList.remove('hidden')
    setTimeout(() => el.classList.add('hidden'), 4000)
  }

  function setLoading(loading) {
    const btn   = document.getElementById('save-btn')
    const label = document.getElementById('save-label')
    btn.disabled = loading
    label.textContent = loading ? 'Guardando...' : (IS_EDIT ? 'Guardar cambios' : 'Crear porfolio')
  }

  window.savePorfolio = async function() {
    const title       = document.getElementById('input-title').value.trim()
    const description = document.getElementById('input-description').value.trim()

    if (!title || !description) {
      showError('El título y la descripción son obligatorios')
      return
    }

    const technologies = [...document.querySelectorAll('#tech-selected [data-id]')].map(el => el.dataset.id)
    const languages    = [...document.querySelectorAll('#lang-selected [data-id]')].map(el => el.dataset.id)
    const codeSnippets = [...document.querySelectorAll('.snippet-item')].map(el => ({
      title:    el.querySelector('.snippet-title').value.trim(),
      language: el.querySelector('.snippet-language').value.trim(),
      code:     el.querySelector('.snippet-code').value
    })).filter(s => s.title && s.language && s.code)

    const body = {
      title,
      description,
      media:        mediaItems,
      technologies,
      languages,
      githubRepo:   document.getElementById('input-github').value.trim() || undefined,
      liveDemo:     document.getElementById('input-demo').value.trim()   || undefined,
      featured:     document.getElementById('input-featured').value === 'true',
      codeSnippets
    }

    setLoading(true)

    try {
      const url    = IS_EDIT ? `/api/porfolios/${PORFOLIO_ID}` : '/api/porfolios'
      const method = IS_EDIT ? 'PUT' : 'POST'

      const res  = await fetch(url, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
      })
      const data = await res.json()

      if (!res.ok) {
        showError(data.error || 'Error al guardar')
        return
      }

      window.location.href = `/porfolios/${data.result._id}`

    } catch (err) {
      console.error(err)
      showError('Error de conexión')
    } finally {
      setLoading(false)
    }
  }
</script>

{% endblock %}
