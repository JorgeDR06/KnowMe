{% extends "base.njk" %}

{% block titulo %}Porfolios — KnowMe{% endblock %}

{% block contenido %}

<div class="min-h-screen bg-[#0a0a0f] text-slate-300">
  <div class="max-w-[1400px] mx-auto px-6 py-8 flex gap-8">

    <aside class="w-72 shrink-0">
      <div class="sticky top-24 flex flex-col gap-6">

        <div>
          <label class="block text-xs font-mono text-emerald-400 uppercase tracking-widest mb-2">// buscar</label>
          <div class="relative">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
            </svg>
            <input id="global-search" type="text" placeholder="título, usuario..." class="w-full bg-[#0f0f18] border border-slate-800 rounded-lg pl-9 pr-4 py-2.5 text-sm text-slate-200 placeholder-slate-600 focus:outline-none focus:border-emerald-500/50 focus:ring-1 focus:ring-emerald-500/20 transition-all font-mono"/>
          </div>
        </div>

        <div>
          <label class="block text-xs font-mono text-emerald-400 uppercase tracking-widest mb-2">// tecnologías</label>
          <div class="relative">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
            </svg>
            <input id="tech-search" type="text" placeholder="buscar tecnología..." autocomplete="off" class="w-full bg-[#0f0f18] border border-slate-800 rounded-lg pl-9 pr-4 py-2.5 text-sm text-slate-200 placeholder-slate-600 focus:outline-none focus:border-emerald-500/50 focus:ring-1 focus:ring-emerald-500/20 transition-all font-mono"/>
            <div id="tech-suggestions" class="hidden absolute z-50 w-full mt-1 bg-[#0f0f18] border border-slate-700 rounded-lg overflow-hidden shadow-xl shadow-black/50 max-h-48 overflow-y-auto"></div>
          </div>
          <div id="tech-selected" class="flex flex-wrap gap-1.5 mt-2"></div>
        </div>

        <div>
          <label class="block text-xs font-mono text-emerald-400 uppercase tracking-widest mb-2">// lenguajes</label>
          <div class="relative">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
            </svg>
            <input id="lang-search" type="text" placeholder="buscar lenguaje..." autocomplete="off" class="w-full bg-[#0f0f18] border border-slate-800 rounded-lg pl-9 pr-4 py-2.5 text-sm text-slate-200 placeholder-slate-600 focus:outline-none focus:border-emerald-500/50 focus:ring-1 focus:ring-emerald-500/20 transition-all font-mono"/>
            <div id="lang-suggestions" class="hidden absolute z-50 w-full mt-1 bg-[#0f0f18] border border-slate-700 rounded-lg overflow-hidden shadow-xl shadow-black/50 max-h-48 overflow-y-auto"></div>
          </div>
          <div id="lang-selected" class="flex flex-wrap gap-1.5 mt-2"></div>
        </div>

        <div>
          <label class="block text-xs font-mono text-emerald-400 uppercase tracking-widest mb-2">// destacados</label>
          <button id="featured-toggle" class="flex items-center gap-3 w-full bg-[#0f0f18] border border-slate-800 rounded-lg px-4 py-2.5 hover:border-emerald-500/40 transition-all">
            <div id="featured-track" class="w-8 h-4 rounded-full bg-slate-700 relative transition-all duration-200 shrink-0">
              <div id="featured-knob" class="w-3 h-3 bg-slate-400 rounded-full absolute top-0.5 left-0.5 transition-all duration-200"></div>
            </div>
            <span class="font-mono text-xs text-slate-400">Solo destacados</span>
          </button>
        </div>

        <button id="clear-filters" class="text-xs font-mono text-slate-600 hover:text-slate-400 transition-colors text-left">× limpiar filtros</button>

      </div>
    </aside>

    <main class="flex-1 min-w-0">
      <div class="flex items-center justify-between mb-6">
        <p class="text-xs font-mono text-slate-500"><span id="results-count">0</span> porfolios encontrados</p>
      </div>

      <div id="skeleton-grid" class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-5">
        {% for i in range(0, 6) %}
        <div class="bg-[#0f0f18] border border-slate-800 rounded-xl overflow-hidden animate-pulse">
          <div class="aspect-video bg-slate-800/50"></div>
          <div class="p-4 flex flex-col gap-2">
            <div class="h-4 bg-slate-800 rounded w-3/4"></div>
            <div class="h-3 bg-slate-800 rounded w-1/2"></div>
            <div class="flex gap-2 mt-1">
              <div class="h-5 w-16 bg-slate-800 rounded"></div>
              <div class="h-5 w-14 bg-slate-800 rounded"></div>
            </div>
          </div>
        </div>
        {% endfor %}
      </div>

      <div id="porfolios-grid" class="hidden grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-5"></div>
      <div id="no-results" class="hidden text-center py-24">
        <p class="font-mono text-slate-600 text-sm">// sin resultados para esa búsqueda</p>
      </div>
    </main>
  </div>
</div>

{% endblock %}