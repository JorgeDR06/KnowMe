{% extends "base.njk" %}

{% block titulo %}Nuevo usuario — KnowMe{% endblock %}

{% block contenido %}

<div class="min-h-screen bg-[#0a0a0f] text-slate-300 flex justify-center px-4 py-16">
  <div class="w-full max-w-md flex flex-col gap-6">

    {# BREADCRUMB #}
    <div class="flex items-center gap-2 text-xs font-mono text-slate-600">
      <a href="/usuarios" class="hover:text-emerald-400 transition-colors">usuarios</a>
      <span>/</span>
      <span class="text-slate-400">nuevo</span>
    </div>

    {# HEADER #}
    <div class="flex flex-col gap-1">
      <p class="text-[10px] font-mono text-amber-400 uppercase tracking-widest">// panel de administración</p>
      <h1 class="text-2xl font-mono font-bold text-slate-100 tracking-tight">Crear usuario</h1>
      <p class="text-sm text-slate-600 font-mono mt-1">El usuario se creará sin necesidad de código de invitación.</p>
    </div>

    {# FORM CARD #}
    <div class="bg-[#0f0f18] border border-slate-800 rounded-2xl overflow-hidden">
      <div class="h-px bg-gradient-to-r from-transparent via-amber-500/30 to-transparent"></div>

      <form action="/api/usuarios" method="post" class="p-8 flex flex-col gap-5">

        {% if error %}
        <div class="flex items-start gap-2.5 px-4 py-3 bg-red-500/5 border border-red-500/20 rounded-lg">
          <span class="text-red-400 font-mono text-xs mt-0.5">✕</span>
          <p class="text-xs font-mono text-red-400">{{ error }}</p>
        </div>
        {% endif %}

        {# Nombre #}
        <div class="flex flex-col gap-1.5">
          <label for="name" class="text-xs font-mono text-emerald-400 uppercase tracking-widest">// nombre</label>
          <input type="text" id="name" name="name" value="{{ formData.name if formData }}"
                 placeholder="Nombre completo..." autocomplete="off" required
                 class="w-full bg-[#0a0a0f] border border-slate-800 rounded-lg px-4 py-2.5 text-sm text-slate-200 placeholder-slate-700 font-mono focus:outline-none focus:border-emerald-500/50 focus:ring-1 focus:ring-emerald-500/20 transition-all"/>
        </div>

        {# Email #}
        <div class="flex flex-col gap-1.5">
          <label for="email" class="text-xs font-mono text-emerald-400 uppercase tracking-widest">// correo electrónico</label>
          <input type="email" id="email" name="email" value="{{ formData.email if formData }}"
                 placeholder="ejemplo@dominio.com" autocomplete="off" required
                 class="w-full bg-[#0a0a0f] border border-slate-800 rounded-lg px-4 py-2.5 text-sm text-slate-200 placeholder-slate-700 font-mono focus:outline-none focus:border-emerald-500/50 focus:ring-1 focus:ring-emerald-500/20 transition-all"/>
        </div>

        {# Contraseña #}
        <div class="flex flex-col gap-1.5">
          <label for="password" class="text-xs font-mono text-emerald-400 uppercase tracking-widest">// contraseña</label>
          <div class="relative">
            <input type="password" id="password" name="password"
                   placeholder="Mínimo 8 caracteres..." autocomplete="new-password" required
                   class="w-full bg-[#0a0a0f] border border-slate-800 rounded-lg px-4 py-2.5 pr-11 text-sm text-slate-200 placeholder-slate-700 font-mono focus:outline-none focus:border-emerald-500/50 focus:ring-1 focus:ring-emerald-500/20 transition-all"/>
            <button type="button" id="toggle-password"
                    class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-600 hover:text-slate-400 transition-colors">
              <svg id="eye-icon" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
              </svg>
            </button>
          </div>
        </div>

        {# Rol #}
        <div class="flex flex-col gap-1.5">
          <label class="text-[10px] font-mono text-emerald-400 uppercase tracking-widest">// rol</label>
          <select name="role"
                  class="bg-[#0a0a0f] border border-slate-700 rounded-lg px-4 py-2.5 text-sm font-mono text-slate-200 focus:outline-none focus:border-emerald-500/50 focus:ring-1 focus:ring-emerald-500/20 transition-all">
            <option value="user"  {% if not formData or formData.role !== 'admin' %}selected{% endif %}>user</option>
            <option value="admin" {% if formData and formData.role === 'admin' %}selected{% endif %}>admin</option>
          </select>
        </div>

        {# Botones #}
        <div class="flex items-center justify-between pt-2">
          <a href="/usuarios" class="text-xs font-mono text-slate-600 hover:text-slate-400 transition-colors">← cancelar</a>
          <button type="submit"
                  class="px-5 py-2.5 bg-emerald-500/10 border border-emerald-500/30 hover:bg-emerald-500/20 hover:border-emerald-500/50 text-emerald-400 font-mono text-sm rounded-lg transition-all">
            Crear usuario →
          </button>
        </div>

      </form>
    </div>

  </div>
</div>

<script>
  const btn   = document.getElementById('toggle-password');
  const input = document.getElementById('password');
  const icon  = document.getElementById('eye-icon');
  const eyeOpen   = `<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>`;
  const eyeClosed = `<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/>`;
  btn.addEventListener('click', () => {
    const show = input.type === 'password';
    input.type = show ? 'text' : 'password';
    icon.innerHTML = show ? eyeClosed : eyeOpen;
  });
</script>

{% endblock %}
